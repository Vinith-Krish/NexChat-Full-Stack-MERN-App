MONGODB_URI=
PORT=5001
JWT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated list of frontend origins allowed to call the API.
# Example: http://localhost:5175,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5175

# Resend email provider for password reset OTP.
RESEND_API_KEY=
MAIL_FROM="NEXCHAT <onboarding@resend.dev>"

# Extra secret added to OTP hash.
OTP_PEPPER=change-this-in-production

# Keep false in production.
DEV_EXPOSE_RESET_OTP=false
